<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- 顶部输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_query"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_query"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="15sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:inputType="text"
            tools:ignore="Autofill" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="@string/btn_send"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/accent" />

        <Button
            android:id="@+id/btn_recommend"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:text="推荐"
            android:textColor="@color/text_primary"
            android:backgroundTint="#FF4CAF50" />
    </LinearLayout>

    <!-- 建议词条 -->
    <HorizontalScrollView
        android:id="@+id/sv_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:visibility="gone"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/ll_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- AI 回复文案 -->
    <TextView
        android:id="@+id/tv_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- 加载指示器 -->
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:visibility="gone"
        android:indeterminateTint="@color/accent" />

    <!-- 错误提示 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textColor="#FFFF5252"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- 推荐列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_playlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- 底部播放状态栏 -->
    <LinearLayout
        android:id="@+id/ll_player_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_card"
        android:visibility="gone">

        <View
            android:id="@+id/view_playing_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/playing_green" />

        <TextView
            android:id="@+id/tv_player_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/player_idle" />

        <Button
            android:id="@+id/btn_pause"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂停"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btn_stop"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>
